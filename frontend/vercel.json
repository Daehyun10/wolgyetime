{
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    }
  ],
  "rewrites": [
    { "source": "/manifest.json", "destination": "/manifest.json" },
    { "source": "/sw.js", "destination": "/sw.js" },
    { "source": "/offline.html", "destination": "/offline.html" },
    { "source": "/icons/(.*)", "destination": "/icons/$1" },
    { "source": "/(.*)", "destination": "/" }
  ]
}